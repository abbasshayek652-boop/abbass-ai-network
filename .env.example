# ===== Mother AI minimal runtime =====
MOTHER_ENV=development
MOTHER_LOG_LEVEL=INFO
MOTHER_DASHBOARD_ORIGIN=http://localhost:8000

# Required to use authenticated control endpoints (/auth/login, /start, /stop, /status)
MOTHER_API_KEY=change-me
MOTHER_JWT_SECRET=change-me

# Optional services
MOTHER_REDIS_URL=redis://localhost:6379/0
MOTHER_DB_URL=sqlite:///mother_trades.db
MOTHER_GATEWAY_URL=http://localhost:8000
MOTHER_WEBHOOK_URL=

# Optional exchange keys (required only for live trading)
MOTHER_BINANCE_KEY=
MOTHER_BINANCE_SECRET=

# Optional Telegram integration
MOTHER_TELEGRAM_TOKEN=
MOTHER_TELEGRAM_ADMINS=
MOTHER_TELEGRAM_OPERATORS=

# Optional advanced telemetry/security
MOTHER_OTLP_ENDPOINT=
MOTHER_FERNET_KEY=

# LinkedIn agent (only needed when using /agents/linkedin/* routes)
LI_CLIENT_ID=
LI_CLIENT_SECRET=
LI_REDIRECT_URI=http://localhost:8000/agents/linkedin/callback
