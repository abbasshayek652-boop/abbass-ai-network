{
  "agents": [
    {
      "key": "learning",
      "module": "ai.learning_engine",
      "class_name": "LearningEngine",
      "enabled": true,
      "config": {
        "tick_seconds": 30,
        "mode": "shadow",
        "db_url": "sqlite:///mother_learning.db",
        "redis_url": "redis://localhost:6379/0",
        "default_timeframe": "1m",
        "symbols": [
          "BTC/USDT",
          "ETH/USDT",
          "PAXG/USDT"
        ],
        "policy_max_caps": {
          "max_notional_per_trade": 15.0,
          "max_total_exposure_usdt": 150.0
        },
        "promotion_thresholds": {
          "sharpe_min": 0.8,
          "max_dd_pct": 0.1,
          "qc_rate_max": 0.02
        }
      }
    },
    {
      "key": "crypto",
      "module": "agents.crypto_agent",
      "class_name": "CryptoTradingAgent",
      "enabled": true,
      "config": {
        "paper": true,
        "strategy": "momentum_ema",
        "allowed_pairs": [
          "BTC/USDT",
          "ETH/USDT",
          "BNB/USDT"
        ],
        "timeframe": "1m",
        "tick_seconds": 15,
        "max_notional_per_trade": 15.0,
        "max_positions_per_symbol": 1,
        "duplicate_cooldown_seconds": 20,
        "fee_bps": 10,
        "slippage_bps": 5,
        "safety_cash_pct": 0.95,
        "session_windows": [
          [
            "00:00",
            "23:59"
          ]
        ],
        "trailing_stop_pct": 0.04,
        "twap_seconds": 20,
        "resume": true,
        "mode": "shadow",
        "router_exchanges": [
          "binance",
          "okx"
        ],
        "canary_live_fraction": 0.1,
        "confirm_live": null,
        "bypass_canary": false,
        "webhook_url": null,
        "db_url": "sqlite:///mother_trades.db",
        "dry_run_passed": true,
        "otlp_endpoint": null
      }
    },
    {
      "key": "gold",
      "module": "agents.gold_agent",
      "class_name": "GoldTradingAgent",
      "enabled": true,
      "config": {
        "paper": true,
        "mode": "shadow",
        "strategy": "momentum_ema",
        "allowed_pairs": [
          "PAXG/USDT"
        ],
        "router_exchanges": [
          "binance",
          "okx",
          "bitget"
        ],
        "timeframe": "1m",
        "tick_seconds": 20,
        "max_notional_per_trade": 15.0,
        "max_positions_per_symbol": 1,
        "duplicate_cooldown_seconds": 20,
        "fee_bps": 10,
        "slippage_bps": 5,
        "safety_cash_pct": 0.95,
        "session_windows": [
          [
            "00:00",
            "23:59"
          ]
        ],
        "trailing_stop_pct": 0.04,
        "twap_seconds": 20,
        "resume": true,
        "max_latency_ms": 1200,
        "deviation_sigma": 5.0,
        "max_gap_pct": 0.07,
        "canary_live_fraction": 0.1,
        "confirm_live": null,
        "bypass_canary": false,
        "webhook_url": null,
        "db_url": "sqlite:///mother_trades.db"
      }
    },
    {
      "key": "content",
      "module": "agent.content_bot",
      "class_name": "ContentAgent",
      "enabled": true,
      "config": {
        "tick_seconds": 15,
        "default_topic": "Mother AI updates"
      }
    },
    {
      "key": "linkedin",
      "module": "agents.linkedin_agent.service",
      "class_name": "LinkedInService",
      "enabled": false,
      "config": {
        "capabilities": [
          "post_text",
          "post_document",
          "schedule"
        ],
        "routes": [
          "/agents/linkedin/login",
          "/agents/linkedin/post/text",
          "/agents/linkedin/post/document",
          "/agents/linkedin/schedule"
        ]
      }
    }
  ]
}
